# Copy this file to .env and fill in your secrets. Never commit .env.

# JVC network password (plaintext; the adapter hashes it internally)
JVC_PASSWORD=

# Philips Hue bridge application key
HUE_APP_KEY=

# Plex X-Plex-Token
PLEX_TOKEN=

# Optional: Tautulli API key for richer now-playing detail (Tautulli Settings ->
# Web Interface -> API). Requires the tautulli block in devices.yaml.
TAUTULLI_API_KEY=

# ---- Pool House (Phase 2) ----
# Office Hue bridge application key (separate bridge from the theater Hue)
HUE_POOLHOUSE_APP_KEY=
# LG G5 webOS client key, returned by the TV the first time it pairs. Leave blank
# on first run, accept the on-screen prompt, then copy the key the adapter logs.
LG_CLIENT_KEY=

# Optional backend bind settings.
# With host networking the container binds this port directly on the host, so
# pick one that is free on your Docker host (8080 collides with many stacks).
APP_BIND_HOST=0.0.0.0
APP_PORT=8487
