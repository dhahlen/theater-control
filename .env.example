# Copy this file to .env and fill in your secrets. Never commit .env.

# JVC network password (plaintext; the adapter hashes it internally)
JVC_PASSWORD=

# Philips Hue bridge application key
HUE_APP_KEY=

# Plex X-Plex-Token
PLEX_TOKEN=

# Optional backend bind settings
APP_BIND_HOST=0.0.0.0
APP_PORT=8080
